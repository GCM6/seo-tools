# libSQL / Turso 连接配置
#
# 本地开发：使用本地 SQLite 文件即可。
#   注意：drizzle-kit 的 turso dialect 不接受“空”的 LIBSQL_AUTH_TOKEN，
#   因此本地 `npm run db:push` 时必须给 token 一个非空占位值（如 local）。
#   对 file: 形式的 URL，该 token 在运行时会被忽略，仅为通过 drizzle-kit 校验。
LIBSQL_URL=file:./veris.db
LIBSQL_AUTH_TOKEN=local

# 生产（Vercel + Turso）：改为真实的 Turso 远程库
#   LIBSQL_URL=libsql://<your-db>-<org>.turso.io
#   LIBSQL_AUTH_TOKEN=<真实的 Turso token>
# 请勿把真实 token 提交进仓库。
