# libSQL / Turso 连接配置
#
# 本地开发：使用本地 SQLite 文件即可。
#   注意：drizzle-kit 的 turso dialect 不接受“空”的 LIBSQL_AUTH_TOKEN，
#   因此本地 `npm run db:push` 时必须给 token 一个非空占位值（如 local）。
#   对 file: 形式的 URL，该 token 在运行时会被忽略，仅为通过 drizzle-kit 校验。
LIBSQL_URL=file:./veris.db
LIBSQL_AUTH_TOKEN=local

# 生产（Vercel + Turso）：改为真实的 Turso 远程库
#   LIBSQL_URL=libsql://<your-db>-<org>.turso.io
#   LIBSQL_AUTH_TOKEN=<真实的 Turso token>
# 请勿把真实 token 提交进仓库。

# BYOK 凭据加密主密钥（SP-G1c）：设置页录入的 API Key 以此 AES-256-GCM 加密入库。
# base64 编码的 32 字节，生成：openssl rand -base64 32。未配置时设置页保存 key 会返回 encryption_unavailable。
CREDENTIALS_ENCRYPTION_KEY=

# Cloudflare Browser Rendering（SP2 render_check 用，REST API 无需部署 Worker）
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# AI 探针（GEO 可见度实测，BYOK：配了哪家的 key 就探哪家）。
# 新建分析勾选的引擎 ∩ 已配置 key 的 provider 才会真正探测；一个都没配时
# AI 可见度 / 答案地图 / SoV 保持「待接入」空态。
OPENAI_API_KEY=
PERPLEXITY_API_KEY=
GEMINI_API_KEY=
# DeepSeek 开放 API 无联网搜索：回答不带引用，证据如实记 web_search_enabled=false
DEEPSEEK_API_KEY=
# 探针模型与采样数可覆盖（默认 gpt-5-mini / sonar / gemini-2.5-flash / deepseek-chat，n 取项目 probe_n=5）
# AI_PROBE_OPENAI_MODEL=
# AI_PROBE_PERPLEXITY_MODEL=
# AI_PROBE_GEMINI_MODEL=
# AI_PROBE_DEEPSEEK_MODEL=
# AI_PROBE_N=1   # 本地调试建议设 1，降低调用成本（20 prompts × n × provider 数）

# Google 搜索前台可见性检查（SEO 第一刀：site:domain）
# 使用 Google Programmable Search / Custom Search JSON API。
# 未配置时不会写入任何合成结果，UI 保持“待接入”。
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=

# Inngest（长任务编排）。本地开发用 Inngest Dev Server，跑：
#   npx inngest-cli@latest dev
# 生产部署前再从 Inngest 控制台取 INNGEST_EVENT_KEY / INNGEST_SIGNING_KEY。
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
# 本地必须设 INNGEST_DEV=1：强制 SDK 把事件发到本地 dev server（8288）。
# 缺失时 SDK 会尝试发往 Inngest 云端 API，因无 event key 而 401，
# 新建分析将报「采集任务派发失败」。生产环境删除本行。
INNGEST_DEV=1
